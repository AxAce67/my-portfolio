# Copy this file to .env.local and fill in real values.
# .env.local is gitignored — never commit actual secrets.

# Required: Appwrite (public project config, not a secret)
VITE_APPWRITE_ENDPOINT=
VITE_APPWRITE_PROJECT_ID=
VITE_CONTACT_EMAIL=

# Required in production
NEXT_PUBLIC_SITE_URL=

# Contact form: Turnstile widget (bot-check shown in the UI) + Web3Forms
# (handles actual email delivery, no backend of ours needed). The
# Web3Forms access key is meant to be public/client-side — see
# https://web3forms.com — it's not a secret like an API key.
NEXT_PUBLIC_TURNSTILE_SITE_KEY=
VITE_WEB3FORMS_ACCESS_KEY=

# GitHub activity card (About section "Development Momentum")
# GITHUB_TOKEN needs commit/contribution read access to your repos —
# a classic PAT with the `repo` scope is the simplest option. A
# fine-grained PAT also works but must explicitly select every repo
# (including private ones) you want counted, or contributions show as
# "restricted" and get reported as 0.
GITHUB_USERNAME=
GITHUB_TOKEN=

# Self-hosted server status (About -> /servers), via Tailscale's API.
# Generate a key at https://login.tailscale.com/admin/settings/keys
# TAILSCALE_TAILNET=- uses the default tailnet for the key's owner.
TAILSCALE_API_KEY=
TAILSCALE_TAILNET=-
