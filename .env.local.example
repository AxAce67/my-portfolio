# Required: Supabase
NEXT_PUBLIC_SUPABASE_URL=your_supabase_url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key

# Required in production: public site URL
NEXT_PUBLIC_SITE_URL=https://akiz.dev

# Required in production: security salt (set a long random string)
AUTH_AUDIT_IP_SALT=replace_with_long_random_secret

# Required when contact form is enabled (Cloudflare Turnstile)
NEXT_PUBLIC_TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=

# Optional: rate limiting with Upstash Redis
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Optional / future use
# RESEND_API_KEY=
# SENTRY_DSN=
# NEXT_PUBLIC_GA_ID=
# PORTFOLIO_ADMIN_USER_ID=
